# ==========================================
# General Security & Routing
# ==========================================
# A random 64-character string used to encrypt session data.
# You can generate one via terminal: openssl rand -hex 32
SECRET_ENCRYPTION_KEY="<<some-secret-key>>"

# Required when running Homarr behind a reverse proxy (like Traefik, Ngx Proxy Manager or Caddy)
AUTH_TRUST_HOST="true"

# ==========================================
# Authentication & SSO (OIDC)
# ==========================================
# We use both OIDC (SSO) and credentials (local login).
# Keeping 'credentials' active is a fallback in case the SSO provider is down.
AUTH_PROVIDERS="oidc,credentials"

# OIDC Provider Details
AUTH_OIDC_ISSUER="https://sso.example.com"
AUTH_OIDC_CLIENT_ID="<<client-id>>"
AUTH_OIDC_CLIENT_SECRET="<<client-secret>>"
AUTH_OIDC_CLIENT_NAME="sso"

# Requested scopes from the OIDC provider
AUTH_OIDC_SCOPE_OVERWRITE="openid,email,profile"