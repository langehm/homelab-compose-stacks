TZ=Europe/Berlin

# ==========================================
# DNS API Credentials (uncomment your provider)
# ==========================================

# --- Cloudflare ---
# CF_Token=<<YOUR_CF_TOKEN>>
# CF_Zone_ID=<<YOUR_CF_ZONE_ID>>

# --- Hetzner ---
# HETZNER_Token=<<YOUR_HETZNER_TOKEN>>

# --- Netcup ---
# NC_CID=<<YOUR_NETCUP_CUSTOMER_ID>>
# NC_Apikey=<<YOUR_NETCUP_API_KEY>>
# NC_Apipw=<<YOUR_NETCUP_API_PW>>

# --- INWX ---
# INWX_User=<<YOUR_INWX_USER>>
# INWX_Password=<<YOUR_INWX_PASSWORD>>

# ==========================================
# Synology DSM Settings
# ==========================================
SYNO_SCHEME=https
SYNO_HOSTNAME=host.docker.internal
SYNO_PORT=5001

SYNO_USERNAME=<<ACME_USER>>
SYNO_PASSWORD=<<USER_PW>>

# Create certificate in DSM if it does not exist
SYNO_CREATE=1

# Label/name of the certificate in DSM (customizable)
SYNO_CERTIFICATE=syn-example-com-wildcard
